# DAC CodeCamp ETNA 2026
# Copiez ce fichier vers .env a la racine du repo.
# Ce meme .env est utilise par Docker Compose et par le backend FastAPI.

DAC_ENV=development
DAC_SCHOOL_MODE=true
DAC_SCHOOL_MAX_INSTANCES=1
DAC_LOG_LEVEL=debug

# Backend FastAPI
BACKEND_BASE_URL=http://backend:8000
FRONTEND_BASE_URL=http://localhost:5173
DATABASE_URL=postgresql://dac:dac@postgres:5432/devops_api_db
SECRET_KEY=change-this-secret-key-for-local-dev
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Exemple valide pour demarrer en local. Changez-le pour un vrai environnement.
FERNET_KEY=2sxscx5ymkGlgp1LBXePogI3ybiEuoAr3m5DYzQfowE=
FERNET_SECRET=2sxscx5ymkGlgp1LBXePogI3ybiEuoAr3m5DYzQfowE=

# IA optionnelle. Le MVP fonctionne en mode mock sans cle API.
OPENAI_API_KEY=
DAC_AI_PROVIDER=mock
DAC_AI_MODEL=gpt-4o-mini

# Frontend Vite
VITE_API_URL=http://localhost:8000
VITE_NODE_ENV=development
